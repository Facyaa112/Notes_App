{
  "name": "notes-app",
  "version": "1.0.0",
  "description": "Менеджер заметок с авторизацией",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "server": "nodemon server/server.js",
    "client": "cd client && npx webpack serve --mode development",
    "build": "cd client && npx webpack --mode production",
    "watch": "cd client && npx webpack --mode development --watch",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "keywords": [
    "express",
    "jwt",
    "jquery",
    "notes"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-loader": "^9.1.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  }
}
